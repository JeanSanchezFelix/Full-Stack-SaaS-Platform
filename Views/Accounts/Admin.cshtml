@model AdminPanelViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Panel de Administración";
    static bool IsPng(byte[] bytes)
    {
        if (bytes.Length < 8) return false;
        return bytes[0] == 0x89
            && bytes[1] == 0x50
            && bytes[2] == 0x4E
            && bytes[3] == 0x47
            && bytes[4] == 0x0D
            && bytes[5] == 0x0A
            && bytes[6] == 0x1A
            && bytes[7] == 0x0A;
    }

    static string? BuildSignatureImageSrc(byte[]? signature)
    {
        if (signature is not { Length: > 0 })
        {
            return null;
        }

        if (IsPng(signature))
        {
            return $"data:image/png;base64,{Convert.ToBase64String(signature)}";
        }

        try
        {
            var asText = System.Text.Encoding.UTF8.GetString(signature);
            const string prefix = "data:image/png;base64,";
            return asText.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) ? asText : null;
        }
        catch
        {
            return null;
        }
    }

    var exportCustomersButtonProps = JsonSerializer.Serialize(new
    {
        label = "Exportar clientes (XLSX)",
        href = Url.Action("ExportCustomers", "Accounts"),
        variant = "primary"
    });
    var exportBookingsButtonProps = JsonSerializer.Serialize(new
    {
        label = "Exportar reservas (XLSX)",
        href = Url.Action("ExportBookings", "Accounts"),
        variant = "primary"
    });

    const int adminTablePageSize = 10;
    var customerContextByLicense = Model.Customers
        .Where(c => !string.IsNullOrWhiteSpace(c.LicenseNumber))
        .ToDictionary(
            c => c.LicenseNumber!.Trim().ToLowerInvariant(),
            c => new
            {
                c.Id,
                c.Bookings
            });
}

