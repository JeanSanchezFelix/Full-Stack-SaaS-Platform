@model CustomerIntakeViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Registro";
    var waiverReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var draftErrors = ViewData["DraftErrors"] as List<string> ?? new List<string>();

    string FirstError(string key)
    {
        return ViewData.ModelState.TryGetValue(key, out var entry)
            ? entry.Errors.FirstOrDefault()?.ErrorMessage ?? string.Empty
            : string.Empty;
    }

    string FieldProps(
        string fieldName,
        string label,
        string? value,
        string type = "text",
        bool required = false,
        string? hint = null,
        bool multiline = false,
        int rows = 3,
        string? wrapperClass = null)
    {
        return JsonSerializer.Serialize(new
        {
            fieldName,
            label,
            value = value ?? string.Empty,
            error = FirstError(fieldName),
            type,
            required,
            hint = hint ?? string.Empty,
            multiline,
            rows,
            wrapperClass = wrapperClass ?? string.Empty
        });
    }
}
<section class="mx-auto max-w-4xl">
    <div class="mb-8">
        <h1 class="text-3xl font-bold tracking-normal text-slate-950">Añade tu información</h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">Llena el formulario para registrarte y poder alquilar nuestros scooters. Asegúrate de proporcionar información precisa para una mejor experiencia.</p>
    </div>
    @if (TempData["CustomerCreated"] is string message)
    {
        <div class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
        @message
        </div>
    }
    <div data-svelte-component="CustomerIntakeEnhancer" data-props='{"formId":"customer-intake-form"}'></div>

    <form id="customer-intake-form" asp-action="Create" method="post" class="space-y-8" novalidate>
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        @if (draftErrors.Count > 0)
        {
            <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                <ul class="list-inside list-disc space-y-1">
                    @foreach (var error in draftErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }
        <div class="grid gap-5 md:grid-cols-2">
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("FirstName", "Nombre", Model.FirstName, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("LastName", "Apellido", Model.LastName, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("LicenseNumber", "Número de licencia", Model.LicenseNumber, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("PhoneNumber", "Número de teléfono", Model.PhoneNumber, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("Email", "Correo electrónico", Model.Email, type: "email", required: false)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("City", "Pueblo de procedencia", Model.City, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("Country", "País", Model.Country, required: true)'></div>
            <div data-svelte-component="TextEntryField" data-props='@FieldProps("HowDidYouHear", "¿Cómo supiste de nosotros?", Model.HowDidYouHear, multiline: true, rows: 3, wrapperClass: "md:col-span-2")'></div>
            @* <div data-svelte-component="TextEntryField" data-props='@FieldProps("Observations", "Comentarios adicionales", Model.Observations, multiline: true, rows: 3, wrapperClass: "md:col-span-2")'></div> *@
        </div>
            <div data-signature-field>
                <label asp-for="ElectronicSignature" class="block text-sm font-medium text-slate-800">
                    @Html.DisplayNameFor(model => model.ElectronicSignature) <span class="text-red-600">*</span>
                </label>
                <input asp-for="ElectronicSignature" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900" />
                <p class="mt-2 text-xs text-slate-500">Requerida para guardar el registro.</p>
                <span asp-validation-for="ElectronicSignature" class="mt-1 block text-sm text-red-600"></span>
            </div>
        <p class="text-xs text-slate-500 text-right">Los campos con <span class="text-red-600">*</span> son requeridos.</p>
        <div class="space-y-4 border-t border-slate-200 pt-6">
            <label class="flex items-start gap-3 text-sm text-slate-700">
                <input asp-for="LiabilityWaiverSigned" class="mt-1 h-4 w-4 rounded border-slate-300 text-slate-950 focus:ring-slate-900" />
                <span>
                    He leído y acepto el
                    <a asp-controller="Customers" asp-action="LiabilityWaiver" asp-route-returnUrl="@waiverReturnUrl" class="font-medium text-slate-950 underline hover:text-slate-700">
                        relevo de responsabilidad
                    </a>
                </span>
            </label>
            <label class="flex items-start gap-3 text-sm text-slate-700">
                <input asp-for="AuthorizeRecontact" class="mt-1 h-4 w-4 rounded border-slate-300 text-slate-950 focus:ring-slate-900" />
                <span>Autorizo recibir ofertas o mensajes promocionales de Scooter de la Bahía por WhatsApp</span>
            </label>
        </div>
        <div class="flex items-center gap-3 border-t border-slate-200 pt-6">
            <button type="submit" class="rounded-md bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2">
                Finalizar registro
            </button>
            <a
                asp-controller="Home"
                asp-action="Index"
                class="rounded-md px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">
                Cancelar
            </a>
        </div>
    </form>
</section>
<script>
    // Save form data to localStorage before navigating away
    const form = document.getElementById('customer-intake-form');
    
    // Restore form data on page load
    window.addEventListener('load', () => {
        const savedData = localStorage.getItem('customer-intake-form');
        if (savedData) {
            try {
                const data = JSON.parse(savedData);
                Object.keys(data).forEach(key => {
                    const input = form.elements[key];
                    if (input) {
                        if (input.type === 'checkbox') {
                            input.checked = data[key];
                        } else {
                            input.value = data[key];
                        }
                    }
                });
                localStorage.removeItem('customer-intake-form');
            } catch (e) {
                console.error('Failed to restore form data:', e);
            }
        }
    });

    // Save form data when clicking the waiver link
    document.addEventListener('click', (e) => {
        if (e.target.href && e.target.href.includes('LiabilityWaiver')) {
            const formData = {};
            Array.from(form.elements).forEach(input => {
                if (input.name && (input.type !== 'hidden' || input.name.startsWith('__'))) {
                    if (input.type === 'checkbox') {
                        formData[input.name] = input.checked;
                    } else {
                        formData[input.name] = input.value;
                    }
                }
            });
            localStorage.setItem('customer-intake-form', JSON.stringify(formData));
        }
    });</script>



