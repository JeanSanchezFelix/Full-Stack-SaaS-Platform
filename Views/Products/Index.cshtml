@model IEnumerable<SvelteHybridMVC.Models.Product>
@{
    ViewData["Title"] = "Product Management";
}

<section class="py-4">
    <h1 class="mb-6 border-b-2 border-blue-600 pb-3 text-4xl font-medium text-slate-900">@ViewData["Title"]</h1>

    <!-- Interactive Svelte component -->
    <div data-svelte-component="ProductGrid"
         data-props='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { products = Model }))'>

        <!-- Razor content for SEO and fallback rendering -->
        <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
            <table class="w-full border-collapse text-left">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="border-b-2 border-slate-200 px-4 py-3 font-semibold text-slate-900">Name</th>
                        <th class="border-b-2 border-slate-200 px-4 py-3 font-semibold text-slate-900">Price</th>
                        <th class="border-b-2 border-slate-200 px-4 py-3 font-semibold text-slate-900">Stock</th>
                        <th class="border-b-2 border-slate-200 px-4 py-3 font-semibold text-slate-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    @foreach (var product in Model)
                    {
                        <tr data-product-id="@product.Id" class="hover:bg-slate-50">
                            <td class="px-4 py-3">@product.Name</td>
                            <td class="px-4 py-3">@product.Price.ToString("C")</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex rounded-md px-2 py-1 text-xs font-semibold text-white @(product.Stock < 10 ? "bg-red-600" : "bg-emerald-600")">
                                    @product.Stock
                                </span>
                            </td>
                            <td class="space-x-2 px-4 py-3">
                                <a asp-action="Edit" asp-route-id="@product.Id" class="inline-flex rounded-md border border-transparent px-3 py-1.5 text-sm font-medium text-blue-700 transition hover:bg-blue-50">Edit</a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="inline-flex rounded-md bg-red-600 px-3 py-1.5 text-sm font-medium text-white transition hover:bg-red-700">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
