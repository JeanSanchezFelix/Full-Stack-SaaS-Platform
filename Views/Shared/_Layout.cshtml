<!DOCTYPE html>
<html lang="es" dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Scooter de la Bahía - Rent a Scooter" />
    <title>@ViewData["Title"] - Scooter de la Bahía</title>
    <link rel="icon" type="image/png" href="~/images/ico.png" />
    <link rel="shortcut icon" type="image/png" href="~/images/ico.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

@{
    string currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? string.Empty;
    string currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? string.Empty;

    Func<string, string, string> isActive = (controller, action) =>
        currentController == controller && currentAction == action
            ? "text-[#EB6A38] font-bold"
            : "text-slate-900";
}

<body class="min-h-screen bg-white text-slate-900 antialiased">
    <div class="flex min-h-screen flex-col">
        <header class="sticky top-0 z-50 bg-white shadow-sm border-b border-zinc-200">
    
            <div class="flex items-center justify-between w-full px-8 h-16">

                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index" class="flex items-center ">
                    <img src="~/images/scooter-de-la-bahia-logo.png"
                         class="h-12 w-auto object-contain transition duration-300 hover:drop-shadow-md" />
                </a>

                <!-- Nav -->
                <nav class="flex flex-1 justify-evenly items-center
                    text-[13px] sm:text-sm md:text-base lg:text-lg xl:text-lg 2xl:text-xl
                    tracking-wide">

                    <a asp-controller="Home" asp-action="Index"
                           class="font-bold transition hover:text-[#EB6A38] @isActive("Home", "Index")">
                        Home
                    </a>

                    <a asp-controller="Customers" asp-action="Create"
                           class="font-bold transition hover:text-[#EB6A38] @isActive("Customers", "Create")">
                        Regístrate
                    </a>

                    <a asp-controller="Bookings" asp-action="Create"
                           class="font-bold transition hover:text-[#EB6A38] @(currentController == "Bookings" && currentAction == "Create" || currentController == "Accounts" && currentAction == "User" ? "text-[#EB6A38] font-bold" : "text-slate-900")">
                        Reserva
                    </a>

                    <a asp-controller="Accounts" asp-action="Admin"
                           class="font-bold transition hover:text-[#EB6A38] @isActive("Accounts", "Admin")">
                        Admin
                    </a>

                </nav>

            </div>

        </header>

        <main class="mx-auto w-full max-w-7xl flex-1 px-6 py-8">
            @RenderBody()
        </main>

        <footer class="border-t border-grey/5 bg-slate-50 text-gray-400">

            <!-- TOP AREA (5 columns: brand spans 2, links span 3 → inner 4 columns) -->
            <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 md:grid-cols-2 lg:grid-cols-5">

                <!-- Column 1: Brand – wider on large screens -->
                <div class="lg:col-span-2 space-y-6">

                    <!-- Logo -->
                    <a asp-controller="Home" asp-action="Index" class="flex items-center">
                        <img src="~/images/monocromatic_logo.png" alt="Scooter de la Bahia" decoding="async"
                             style="height: 4rem; width: auto; max-width: 100%;" />
                    </a>

                    <!-- descriptions + social -->
                    <div class="flex flex-col lg:flex-row lg:gap-8 lg:items-start">

                        <!-- Descriptions block -->
                        <div class="flex-1 space-y-3">
                            <p class="max-w-xs text-sm text-gray-500">
                                Explora la Bahía de Cataño en scooter y disfruta vistas, comida y ambiente familiar.
                            </p>
                            <p class="max-w-xs text-sm text-gray-500">
                                Diversión, libertad y experiencia frente al mar.
                            </p>
                        </div>

                        <!-- Social / Contact block -->
                        <div class="flex flex-col gap-3 text-gray-500 mt-6 lg:mt-0 ">
                            <!-- Social Icons + Location -->
                            <div class="flex items-center gap-4">
                                <div class="flex items-center gap-4">
                                    <!-- Facebook -->
                                    <a href="https://www.facebook.com/p/Scooter-la-bahia-cata%C3%B1o-100066920440861/"
                                           target="_blank" rel="noopener noreferrer"
                                           class="transition hover:text-[#EB6A38]" aria-label="Facebook">
                                        <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             stroke-linecap="round" stroke-linejoin="round">
                                            <path
                                            d="M18 2h-3a6 6 0 0 0-6 6v4h-2v4h2v6h4v-6h3l1-4h-4V8a2 2 0 0 1 2-2h1z" />
                                        </svg>
                                    </a>
                                    <!-- Instagram -->
                                    <a href="https://www.instagram.com/scooterdelabahia/" target="_blank"
                                           rel="noopener noreferrer" class="transition hover:text-[#EB6A38]"
                                           aria-label="Instagram">
                                        <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                            <circle cx="17.5" cy="6.5" r="1.5" />
                                        </svg>
                                    </a>
                                </div>
                                <div class="h-5 w-px bg-gray-500"></div>
                                <!-- Location -->
                                <a href="https://maps.app.goo.gl/xPJTjGGBETvtVGSF8" target="_blank"
                                       class="flex items-center gap-2 transition hover:text-[#EB6A38]"
                                       aria-label="Location">
                                    <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                    <span class="text-sm">Bahía de Cataño</span>
                                </a>
                            </div>

                            <!-- Email -->
                            <a href="mailto:scootersdelabahia@gmail.com"
                                   class="flex items-center gap-2 transition hover:text-[#EB6A38]" aria-label="Email">
                                <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="4" width="20" height="16" rx="2" />
                                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                                </svg>
                                <span class="text-sm">scootersdelabahia@gmail.com</span>
                            </a>

                            <!-- Phone -->
                            <a href="tel:+19392191245" class="flex items-center gap-2 transition hover:text-[#EB6A38]"
                                   aria-label="Phone">
                                <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2
                                    19.79 19.79 0 0 1-8.63-3.07
                                    19.5 19.5 0 0 1-6-6
                                    19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3
                                    a2 2 0 0 1 2 1.72c.12.86.31 1.7.57 2.5a2
                                    2 0 0 1-.45 2.11L8.09 9.91
                                    a16 16 0 0 0 6 6l1.58-1.58a2
                                    2 0 0 1 2.11-.45c.8.26 1.64.45 2.5.57
                                    A2 2 0 0 1 22 16.92z" />
                                </svg>
                                <span class="text-sm">(939) 219-1245</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right side: 4 columns of links (now spans 3 grid columns, holds 4 inner columns) -->
                <div class="grid grid-cols-2 gap-10 lg:col-span-3 lg:grid-cols-4">

                    <!-- Column 2: Services -->
                    <div>
                        <h3 class="mb-4 font-semibold text-black">Servicios de Alquiler</h3>
                        <ul class="space-y-3 text-sm text-gray-400">
                            <li>Scooter</li>
                            <li>E-bike</li>
                        </ul>
                    </div>

                    <!-- Column 3: Horarios -->
                    <div>
                        <h3 class="mb-4 font-semibold text-black">Horarios</h3>
                        <ul class="space-y-3 text-sm text-gray-400">
                            <li>‣ Viernes: 5pm - 10pm</li>
                            <li>‣ Sábado: 2pm - 10pm</li>
                            <li>‣ Domingo: 2pm - 9pm</li>
                        </ul>
                    </div>

                    <!-- Column 4: Links -->
                    <div>
                        <h3 class="mb-4 font-semibold text-black">Links</h3>
                        <ul class="space-y-3 text-sm">
                            <li><a href="#about" class="hover:text-[#EB6A38] transition">About</a></li>
                            <li><a href="#scooters" class="hover:text-[#EB6A38] transition">Scooters</a></li>
                            <li><a href="#pricing" class="hover:text-[#EB6A38] transition">Pricing</a></li>
                            <li><a href="#contact" class="hover:text-[#EB6A38] transition">Contact</a></li>
                        </ul>
                    </div>

                    <!-- Column 5: Info -->
                    <div>
                        <h3 class="mb-4 font-semibold text-black">Info</h3>
                        <ul class="space-y-3 text-sm">
                            <li>Política de privacidad</li>
                            <li>Términos de servicio</li>
                            <li>FAQs</li>
                        </ul>
                    </div>

                </div>
            </div>

            <!-- BOTTOM BAR -->
            <div class="border-t border-grey/5 text-slate-500 bg-slate-100 border-slate-200">
                <div
                    class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-sm text-black-500 md:flex-row">
                    <p>
                        &copy; @DateTime.Now.Year <strong class="text-black-300">Scooter de la Bahía</strong> — Todos
                        los derechos reservados
                    </p>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/_svelte/client.js" type="module" defer asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
