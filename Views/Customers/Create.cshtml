@model CustomerIntakeViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Registro";
    var waiverReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string FirstError(string key)
    {
        return ViewData.ModelState.TryGetValue(key, out var entry)
            ? entry.Errors.FirstOrDefault()?.ErrorMessage ?? string.Empty
            : string.Empty;
    }

    string FieldProps(
        string fieldName,
        string label,
        string? value,
        string type = "text",
        bool required = false,
        string? hint = null,
        bool multiline = false,
        int rows = 3,
        string? wrapperClass = null)
    {
        return JsonSerializer.Serialize(new
        {
            fieldName,
            label,
            value = value ?? string.Empty,
            error = FirstError(fieldName),
            type,
            required,
            hint = hint ?? string.Empty,
            multiline,
            rows,
            wrapperClass = wrapperClass ?? string.Empty
        });
    }

    string ButtonProps(
        string label,
        string? href = null,
        string type = "button",
        string variant = "primary",
        string? extraClass = null)
    {
        return JsonSerializer.Serialize(new
        {
            label,
            href = href ?? string.Empty,
            type,
            variant,
            extraClass = extraClass ?? string.Empty
        });
    }
}
<section class="mx-auto max-w-4xl">
    <div class="mb-8">
        <h1 class="text-3xl font-bold tracking-normal text-slate-950">Añade tu información</h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">Llena el formulario para registrarte y poder alquilar
            nuestros scooters. Asegúrate de proporcionar información precisa para una mejor experiencia.</p>
    </div>
    @if (TempData["CustomerCreated"] is string message)
    {
        <div class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
            @message
        </div>
    }

    <form id="customer-intake-form" asp-action="Create" method="post" class="space-y-8" novalidate>
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly"
                class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        <div class="grid gap-5 md:grid-cols-2">
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("FirstName", "Nombre", Model.FirstName, required: true)'></div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("LastName", "Apellido", Model.LastName, required: true)'></div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("LicenseNumber", "Número de licencia", Model.LicenseNumber, required: true)'>
            </div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("PhoneNumber", "Número de teléfono", Model.PhoneNumber, required: true)'></div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("Email", "Correo electrónico", Model.Email, type: "email", required: false)'>
            </div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("City", "Pueblo de procedencia", Model.City, required: true)'></div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("Country", "País", Model.Country, required: true)'></div>
            <div data-svelte-component="TextEntryField"
                    data-props='@FieldProps("HowDidYouHear", label: "¿Dónde o cómo te enteraste de nosotros?", Model.HowDidYouHear, multiline: true, rows: 1, wrapperClass: "md:col-span-2")'>
            </div>
        </div>

        <div data-svelte-component="CustomerIntakeEnhancer" data-props='{"formId":"customer-intake-form"}'></div>
        
        <div data-signature-field>
            <div data-signature-dimmable>
                <label asp-for="ElectronicSignature" class="block text-sm font-medium text-slate-800">
                    @Html.DisplayNameFor(model => model.ElectronicSignature) <span class="text-red-600">&nbsp*</span>
                </label>
                <input asp-for="ElectronicSignature" type="hidden" />
                <div class="mt-2 overflow-hidden rounded-md border border-slate-300 bg-white">
                    <canvas id="electronic-signature-pad" class="block h-40 w-full touch-none"></canvas>
                </div>
                <div class="mt-2 flex items-center justify-between">
                    <p class="text-xs text-slate-500">Dibuja tu firma en el recuadro para guardar el registro.</p>
                    <button type="button" id="clear-signature-btn"
                            class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">
                        Limpiar firma
                    </button>
                </div>
                <span asp-validation-for="ElectronicSignature" class="mt-1 block text-sm text-red-600"></span>
            </div>
            <p class="text-xs text-slate-500 text-left mt-2">Los campos con <span class="text-red-600">*</span> son
                requeridos.</p>
        </div>
    
        <div class="space-y-4 border-t border-slate-200 pt-6">
            <label class="flex items-start gap-3 text-sm text-slate-700">
                <input asp-for="LiabilityWaiverSigned"
                        class="mt-1 h-4 w-4 rounded border-slate-300 text-slate-950 focus:ring-slate-900" />
                <span>
                    He leído y acepto el
                    <a asp-controller="Customers" asp-action="LiabilityWaiver" asp-route-returnUrl="@waiverReturnUrl"
                            class="font-medium text-slate-950 underline hover:text-slate-700">
                        relevo de responsabilidad
                    </a>
                </span>
            </label>
            <span data-waiver-client-error class="hidden mt-1 text-sm text-red-600">Debes aceptar el relevo de
                responsabilidad para continuar.</span>
            <label class="flex items-start gap-3 text-sm text-slate-700">
                <input asp-for="AuthorizeRecontact"
                        class="mt-1 h-4 w-4 rounded border-slate-300 text-slate-950 focus:ring-slate-900" />
                <span>Autorizo recibir ofertas o mensajes promocionales de Scooter de la Bahía por correo electrónico o
                    WhatsApp</span>
            </label>
        </div>
        <div class="flex items-center gap-3 border-t border-slate-200 pt-6">
        <div data-svelte-component="ActionButton" data-props='@ButtonProps("Finalizar registro", type: "submit", variant: "primary")'></div>
        <div data-svelte-component="ActionButton" data-props='@ButtonProps("Cancelar", href: Url.Action("Index", "Home"), variant: "secondary")'></div>
        </div>
    </form>
</section>
<script>
    const form = document.getElementById('customer-intake-form');
    const draftStorageKey = 'customer-intake-form';
    let allowDraftPersistence = true;

    const collectFormDraft = () => {
        if (!form) return {};
        const formData = {};
        Array.from(form.elements).forEach(input => {
            if (!input?.name || input.name === 'ElectronicSignature' || input.name === 'LiabilityWaiverSigned') {
                return;
            }
            if (input.type === 'hidden' && !input.name.startsWith('__')) {
                return;
            }
            if (input.type === 'checkbox') {
                formData[input.name] = input.checked;
            } else {
                formData[input.name] = input.value;
            }
        });
        return formData;
    };

    const saveFormDraft = () => {
        if (!allowDraftPersistence) return;
        if (!form) return;
        try {
            localStorage.setItem(draftStorageKey, JSON.stringify(collectFormDraft()));
        } catch (e) {
            console.error('Failed to save form data:', e);
        }
    };

    const restoreFormDraft = () => {
        if (!form) return;
        const savedData = localStorage.getItem(draftStorageKey);
        if (!savedData) return;
        try {
            const data = JSON.parse(savedData);
            Object.keys(data).forEach(key => {
                if (key === 'LiabilityWaiverSigned') {
                    return;
                }

                const checkboxInput = form.querySelector(`input[name="${key}"][type="checkbox"]`);
                if (checkboxInput) {
                    checkboxInput.checked = Boolean(data[key]);
                    return;
                }

                const input = form.elements[key];
                if (!input) return;
                input.value = data[key];
            });
            localStorage.removeItem(draftStorageKey);
            form.dispatchEvent(new Event('input', { bubbles: true }));
            form.dispatchEvent(new Event('change', { bubbles: true }));
        } catch (e) {
            console.error('Failed to restore form data:', e);
        }
    };

    // Restore on page load, and save on refresh/navigation.
    window.addEventListener('load', restoreFormDraft);
    window.addEventListener('beforeunload', saveFormDraft);
    form?.addEventListener('input', saveFormDraft);
    form?.addEventListener('change', saveFormDraft);

    // Keep explicit waiver-link save as well (works for click on nested elements too).
    document.addEventListener('click', (e) => {
        const link = e.target?.closest?.('a[href*="LiabilityWaiver"]');
        if (link) {
            saveFormDraft();
        }
    });

    const waiverCheckbox = form.querySelector('input[name="LiabilityWaiverSigned"][type="checkbox"]');
    const waiverClientError = form.querySelector('[data-waiver-client-error]');
    const signatureInput = form.querySelector('input[name="ElectronicSignature"]');
    const signatureCanvas = document.getElementById('electronic-signature-pad');
    const clearSignatureBtn = document.getElementById('clear-signature-btn');
    const signatureDimmable = form.querySelector('[data-signature-dimmable]');
    const signatureCtx = signatureCanvas?.getContext('2d');
    let isDrawing = false;
    let hasSignature = false;
    const requiredFieldMessages = {
        FirstName: 'El nombre es requerido.',
        LastName: 'El apellido es requerido.',
        LicenseNumber: 'El numero de licencia es requerido.',
        PhoneNumber: 'El numero de telefono es requerido.',
        City: 'El pueblo de procedencia es requerido.',
        Country: 'El pais es requerido.'
    };

    const getFieldErrorElement = (fieldName) => {
        const field = form?.querySelector(`[name="${fieldName}"]`);
        if (!field) return null;
        return field.closest('div')?.querySelector('span.mt-1.block.text-sm.text-red-600') ?? null;
    };

    const syncRequiredFieldError = (fieldName) => {
        const field = form?.querySelector(`[name="${fieldName}"]`);
        const errorElement = getFieldErrorElement(fieldName);
        if (!field || !errorElement) return true;

        const isValid = String(field.value ?? '').trim().length > 0;
        errorElement.textContent = isValid ? '' : (requiredFieldMessages[fieldName] ?? 'Este campo es requerido.');
        return isValid;
    };

    const syncAllRequiredFieldErrors = () => {
        let allValid = true;
        Object.keys(requiredFieldMessages).forEach((fieldName) => {
            const isValid = syncRequiredFieldError(fieldName);
            allValid = allValid && isValid;
        });
        return allValid;
    };

    const syncWaiverClientError = () => {
        if (!waiverCheckbox || !waiverClientError) return;
        waiverClientError.classList.toggle('hidden', waiverCheckbox.checked);
    };

    const resizeSignaturePad = () => {
        if (!signatureCanvas || !signatureCtx) return;

        const { width, height } = signatureCanvas.getBoundingClientRect();
        if (width <= 0 || height <= 0) return;

        const ratio = window.devicePixelRatio || 1;
        const previousData = hasSignature ? signatureCanvas.toDataURL('image/png') : null;
        signatureCanvas.width = Math.floor(width * ratio);
        signatureCanvas.height = Math.floor(height * ratio);
        signatureCtx.setTransform(ratio, 0, 0, ratio, 0, 0);
        signatureCtx.lineCap = 'round';
        signatureCtx.lineJoin = 'round';
        signatureCtx.lineWidth = 2;
        signatureCtx.strokeStyle = '#0f172a';

        if (previousData) {
            const image = new Image();
            image.onload = () => signatureCtx.drawImage(image, 0, 0, width, height);
            image.src = previousData;
        } else {
            signatureCtx.clearRect(0, 0, width, height);
        }
    };
    const toCapitalizedWords = (value) => {
        return String(value ?? '')
            .toLowerCase()
            .replace(/\s+/g, ' ')   // normalize multiple spaces
            .replace(/(^|\s)\S/g, (char) => char.toUpperCase());
    };

    const capitalizeFields = new Set([
        'FirstName',
        'LastName',
        'City',
        'Country'
    ]);

    document.addEventListener('input', (event) => {
        const field = event.target;

        if (!field || !capitalizeFields.has(field.name)) return;

        // avoid interfering with composition (mobile / IME input)
        if (field.isComposing) return;

        const value = field.value;
        const normalized = toCapitalizedWords(value);

        if (value === normalized) return;

        const start = field.selectionStart;
        const end = field.selectionEnd;

        field.value = normalized;

        // restore cursor safely
        requestAnimationFrame(() => {
            if (document.activeElement === field) {
                field.setSelectionRange(start, end);
            }
        });
    });
    document.addEventListener('blur', (event) => {
        const field = event.target;

        if (!field || !capitalizeFields.has(field.name)) return;

        field.value = toCapitalizedWords(field.value);
    });
    const capitalizeFirstLetterOnly = (value) => {
        const str = String(value ?? '').toLowerCase();
        return str.charAt(0).toUpperCase() + str.slice(1);
    };

    const fields = new Set([
        'HowDidYouHear'
    ]);

    document.addEventListener('input', (event) => {
        const field = event.target;

        if (!field || !fields.has(field.name)) return;

        if (field.isComposing) return;

        const value = field.value;
        const normalized = capitalizeFirstLetterOnly(value);

        if (value === normalized) return;

        const start = field.selectionStart;
        const end = field.selectionEnd;

        field.value = normalized;

        requestAnimationFrame(() => {
            if (document.activeElement === field) {
                field.setSelectionRange(start, end);
            }
        });
    });
    document.addEventListener('blur', (event) => {
        const field = event.target;

        if (!field || field.name !== 'HowDidYouHear') return;

        const value = String(field.value ?? '').toLowerCase();
        field.value = value.charAt(0).toUpperCase() + value.slice(1);
    }, true);

    const saveSignatureToInput = () => {
        if (!signatureInput || !signatureCanvas) return;
        signatureInput.value = hasSignature ? signatureCanvas.toDataURL('image/png') : '';
    };

    const clearSignature = () => {
        if (!signatureCanvas || !signatureCtx) return;
        const { width, height } = signatureCanvas.getBoundingClientRect();
        signatureCtx.clearRect(0, 0, width, height);
        hasSignature = false;
        saveSignatureToInput();
    };

    const getCanvasPoint = (event) => {
        if (!signatureCanvas) return { x: 0, y: 0 };
        const rect = signatureCanvas.getBoundingClientRect();
        const point = event.touches ? event.touches[0] : event;
        return {
            x: point.clientX - rect.left,
            y: point.clientY - rect.top
        };
    };

    const beginDraw = (event) => {
        if (!signatureCtx || waiverCheckbox?.checked === false) return;
        isDrawing = true;
        const { x, y } = getCanvasPoint(event);
        signatureCtx.beginPath();
        signatureCtx.moveTo(x, y);
        event.preventDefault();
    };

    const draw = (event) => {
        if (!isDrawing || !signatureCtx) return;
        const { x, y } = getCanvasPoint(event);
        signatureCtx.lineTo(x, y);
        signatureCtx.stroke();
        hasSignature = true;
        saveSignatureToInput();
        event.preventDefault();
    };

    const endDraw = () => {
        if (!signatureCtx) return;
        isDrawing = false;
        signatureCtx.closePath();
    };

    const syncSignatureLock = () => {
        const enabled = waiverCheckbox?.checked ?? false;
        signatureCanvas?.classList.toggle('pointer-events-none', !enabled);
        signatureDimmable?.classList.toggle('opacity-50', !enabled);
        if (!enabled) {
            clearSignature();
        }
    };

    resizeSignaturePad();
    window.addEventListener('resize', resizeSignaturePad);
    clearSignatureBtn?.addEventListener('click', clearSignature);
    signatureCanvas?.addEventListener('mousedown', beginDraw);
    signatureCanvas?.addEventListener('mousemove', draw);
    signatureCanvas?.addEventListener('mouseup', endDraw);
    signatureCanvas?.addEventListener('mouseleave', endDraw);
    signatureCanvas?.addEventListener('touchstart', beginDraw, { passive: false });
    signatureCanvas?.addEventListener('touchmove', draw, { passive: false });
    signatureCanvas?.addEventListener('touchend', endDraw);

    waiverCheckbox?.addEventListener('change', syncWaiverClientError);
    waiverCheckbox?.addEventListener('change', syncSignatureLock);
    Object.keys(requiredFieldMessages).forEach((fieldName) => {
        const field = form?.querySelector(`[name="${fieldName}"]`);
        field?.addEventListener('input', () => syncRequiredFieldError(fieldName));
        field?.addEventListener('blur', () => syncRequiredFieldError(fieldName));
    });

    form.addEventListener('submit', (e) => {
        const requiredFieldsValid = syncAllRequiredFieldErrors();
        if (!requiredFieldsValid) {
            e.preventDefault();
            const firstMissingFieldName = Object.keys(requiredFieldMessages)
                .find((fieldName) => !String(form?.querySelector(`[name="${fieldName}"]`)?.value ?? '').trim().length);
            form?.querySelector(`[name="${firstMissingFieldName}"]`)?.focus();
            return;
        }

        const waiverChecked = waiverCheckbox?.checked;
        if (!waiverChecked) {
            e.preventDefault();
            syncWaiverClientError();
            waiverCheckbox?.focus();
            return;
        }

        saveSignatureToInput();
        if (!signatureInput?.value) {
            e.preventDefault();
            syncWaiverClientError();
            return;
        }

        // Submission is valid; stop saving draft during navigation and clear it.
        allowDraftPersistence = false;
        localStorage.removeItem(draftStorageKey);
    });

    syncSignatureLock();
</script>







