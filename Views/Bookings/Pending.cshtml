@model IReadOnlyList<BookingListItemViewModel>

@{
    ViewData["Title"] = "Reservas";
}

<section class="mx-auto max-w-6xl">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-normal text-slate-950">Reservas</h1>
            <p class="mt-2 text-sm leading-6 text-slate-600">Aprueba reservas pendientes para crear la entrada en rental.</p>
        </div>
        <a asp-action="Create" class="rounded-md bg-slate-950 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800">Nueva reserva</a>
    </div>

    @if (TempData["BookingApproved"] is string message)
    {
        <div class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
            @message
        </div>
    }

    <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left text-slate-600">
                <tr>
                    <th class="px-4 py-3 font-semibold">Cliente</th>
                    <th class="px-4 py-3 font-semibold">Licencia</th>
                    <th class="px-4 py-3 font-semibold">Fecha</th>
                    <th class="px-4 py-3 font-semibold">Equipo</th>
                    <th class="px-4 py-3 font-semibold">Estado</th>
                    <th class="px-4 py-3 font-semibold"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var booking in Model)
                {
                    <tr>
                        <td class="px-4 py-3 font-medium text-slate-900">@booking.CustomerName</td>
                        <td class="px-4 py-3 text-slate-600">@booking.LicenseNumber</td>
                        <td class="px-4 py-3 text-slate-600">@booking.RequestedStart.ToString("g")</td>
                        <td class="px-4 py-3 text-slate-600">@booking.ScooterQuantity scooter / @booking.EbikeQuantity e-bike</td>
                        <td class="px-4 py-3 text-slate-600">@booking.Status</td>
                        <td class="px-4 py-3 text-right">
                            @if (booking.Status == "pending")
                            {
                                <form asp-action="Approve" asp-route-id="@booking.Id" method="post">
                                    <button type="submit" class="rounded-md bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700">
                                        Aprobar
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
