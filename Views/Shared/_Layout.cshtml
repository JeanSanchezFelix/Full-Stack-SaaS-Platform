<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A hybrid system that combines ASP.NET MVC and Svelte" />
    <title>@ViewData["Title"] - SvelteHybridMVC</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="min-h-screen bg-white text-slate-900 antialiased">
    <div class="flex min-h-screen flex-col">
        <header class="sticky top-0 z-50 bg-slate-950 shadow-sm">
            <nav class="mx-auto flex max-w-7xl items-center gap-6 px-6 py-4">
                <a asp-controller="Home" asp-action="Index" class="border-r border-white/20 pr-6 text-xl font-semibold text-white">
                    SvelteHybridMVC
                </a>
                <a asp-controller="Home" asp-action="Index" class="rounded-md px-3 py-2 font-medium text-white/80 transition hover:bg-white/10 hover:text-white focus:bg-white/10 focus:text-white">
                    Home
                </a>
            </nav>
        </header>

        <main class="mx-auto w-full max-w-7xl flex-1 px-6 py-8">
            @RenderBody()
        </main>

        <footer class="border-t border-slate-200 bg-slate-50 px-6 py-6 text-center text-slate-500">
            <p>&copy; @DateTime.Now.Year - <strong>SvelteHybridMVC</strong> | Hybrid ASP.NET + Svelte system</p>
        </footer>
    </div>

    <script src="~/_svelte/client.js" type="module" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
